# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis:
  "Tool to extract vendor library dependencies from Dune files and generate .mli interface files from their .cmi files."
description:
  "dune-ai-context parses the external library dependencies of an OCaml project using `dune describe external-lib-deps`, filters out `ppx_` packages, locates the corresponding `.cmi` files in the OPAM switch, and writes their interface signatures to `vendor_interfaces/<library>.mli`. This provides a convenient context for AI‑assisted coding tools."
maintainer: ["ZFY <zf.yuan.y@gmail.com>"]
authors: ["ZFY <zf.yuan.y@gmail.com>"]
license: "MIT"
tags: ["ocaml" "dune" "vendor" "cmi" "interface" "AI tool" "LLM"]
homepage: "https://github.com/zenfey/dune-ai-context"
doc: "https://github.com/zenfey/dune-ai-context"
bug-reports: "https://github.com/zenfey/dune-ai-context/issues"
depends: [
  "ocaml"
  "dune" {>= "3.1"}
  "sexplib"
  "str"
  "unix"
  "compiler-libs" {= "common"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/zenfey/dune-ai-context.git"
